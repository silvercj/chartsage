# Copy to bi/.env (gitignored) and fill in. See bi/README.md for the full walkthrough.

# ── PostHog (read-only product analytics via the HogQL query API) ─────────────
# Reuse the personal API key + project id from the app's own root .env.
# Query host is the APP host (us.posthog.com), NOT the ingestion host (us.i.posthog.com).
EVIDENCE_POSTHOG_HOST=https://us.posthog.com
EVIDENCE_POSTHOG_PROJECT_ID=your_posthog_project_id
EVIDENCE_POSTHOG_API_KEY=phx_your_personal_api_key

# ── Supabase Postgres (read-only BI role) ────────────────────────────────────
# After running docs/migrations/bi-readonly-role.sql, take the Supabase
# "Session pooler" connection string (Project Settings → Database) and split it:
#   • host  = aws-0-<region>.pooler.supabase.com
#   • user  = chartsage_readonly.<project-ref>   (pooler needs the .<ref> suffix)
#             …or just  chartsage_readonly  if you use the direct connection
#   • password = the role password you set in the migration
#       ⚠️ escape any $ in the password as \$  (Evidence loads .env via Vite, which
#       expands $). e.g. pa$1word  →  pa\$1word.  Quoting does NOT help.
# Port (5432), database (postgres), schema (public) and SSL live in
# sources/supabase/connection.yaml — not here.
EVIDENCE_SOURCE__supabase__host=
EVIDENCE_SOURCE__supabase__user=
EVIDENCE_SOURCE__supabase__password=
